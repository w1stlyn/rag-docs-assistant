# --- YandexGPT credentials -----------------------------------------------
# Получить API-ключ и folder_id: https://console.cloud.yandex.ru/
# Сервисный аккаунт -> роли ai.languageModels.user + ai.embeddings.user
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# --- Модели (значения по умолчанию подходят, можно не менять) -------------
YANDEX_LLM_MODEL=yandexgpt-lite/latest
YANDEX_EMBED_DOC_MODEL=text-search-doc/latest
YANDEX_EMBED_QUERY_MODEL=text-search-query/latest

# --- Параметры RAG --------------------------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K=4
TEMPERATURE=0.2
MAX_TOKENS=2000

# --- Хранилище ------------------------------------------------------------
VECTOR_DB_PATH=./chroma_db
COLLECTION_NAME=documents
